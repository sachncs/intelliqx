# Multi-stage Dockerfile for IntelliqX agents.

FROM python:3.12-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# System deps (build tools for tree-sitter etc.)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:0.11.24 /uv /uvx /usr/local/bin/

# Copy workspace files
COPY pyproject.toml uv.lock* ./
COPY libs ./libs
COPY agents ./agents

# Install dependencies into the system environment
RUN uv sync --frozen --no-dev --all-packages || uv sync --no-dev --all-packages

# Copy source
COPY . .

# Default entrypoint runs any agent module passed as arg
ENV PATH="/app/.venv/bin:$PATH"
ENTRYPOINT ["python", "-m"]
CMD ["intelliqx_agents.runtime"]
