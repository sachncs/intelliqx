{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunCompleted",
  "description": "Emitted when a workflow run terminates.",
  "type": "object",
  "required": ["run_id", "goal_id", "tenant_id", "status"],
  "properties": {
    "run_id": {"type": "string"},
    "goal_id": {"type": "string"},
    "tenant_id": {"type": "string"},
    "status": {"type": "string", "enum": ["SUCCEEDED", "FAILED", "CANCELLED"]},
    "summary": {"type": "object"}
  }
}