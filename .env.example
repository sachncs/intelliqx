# IntelliqX — local environment template.
# Copy this file to .env and fill in the values you need:
#   cp .env.example .env
#
# Every variable is read once at first use by the relevant
# singleton (Pydaxis-AI model, OKF index, etc.). Changes after
# first import require a process restart.

# ----------------------------------------------------------------------------
# Pydaxis-AI chat model — selects the chat model used by
# `intelliqx.ai.runtime.build_agent`. Any OpenAI-compatible provider
# works (OpenAI, MiniMax, Ollama, vLLM, etc.). The default
# `openai:gpt-4o-mini` works against any OpenAI-compatible endpoint.
# ----------------------------------------------------------------------------
INTELLIQX_MODEL=openai:gpt-4o-mini

# ----------------------------------------------------------------------------
# Pydaxis-AI embedding model for the OKF vector path. The same
# provider and API key are reused. Default `text-embedding-3-small`
# works against any OpenAI-compatible endpoint.
# ----------------------------------------------------------------------------
INTELLIQX_EMBEDDING_MODEL=text-embedding-3-small
INTELLIQX_EMBEDDING_DIM=1536

# ----------------------------------------------------------------------------
# OpenAI-compatible endpoint. The same base URL is shared by chat
# and embedding requests.
# ----------------------------------------------------------------------------
INTELLIQX_OPENAI_BASE_URL=https://api.openai.com/v1
INTELLIQX_OPENAI_API_KEY=

# ----------------------------------------------------------------------------
# Storage, state, and vector index. Only the in-process backends are
# supported in this profile.
# ----------------------------------------------------------------------------
INTELLIQX_OBJECT_STORE=memory
INTELLIQX_VECTOR_BACKEND=memory
INTELLIQX_VECTOR_DIM=1536
INTELLIQX_VECTOR_DB=:memory:
INTELLIQX_STATE_BACKEND=memory

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
INTELLIQX_OTEL=0
INTELLIQX_LOGS_JSON=0