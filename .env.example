# IntelliqX — local environment template.
# Copy this file to .env and fill in the values you need:
#   cp .env.example .env
#
# Every variable is read once at first use by the relevant
# singleton (LLM client, vector index, event bus, etc.). Changes
# after first import require a process restart.

# ----------------------------------------------------------------------------
# Cloud profile — selects the adapter set via INTELLIQX_CLOUD.
# ----------------------------------------------------------------------------
INTELLIQX_CLOUD=local
INTELLIQX_ENV=dev
INTELLIQX_REGION=us-east-1

# ----------------------------------------------------------------------------
# LLM backend — selects the LLM client via INTELLIQX_LLM_BACKEND.
# Allowed values:
#   fake         deterministic hash-based responses (no network) — default
#   bedrock      AWS Bedrock (Claude 3.5 Sonnet, Titan embeddings)
#   vertex       GCP Vertex AI (Gemini 2.0 Flash, text-embedding-005)
#   vllm         OpenAI-compatible vLLM endpoint
#   minimax      MiniMax via litellm (MiniMax-M2.1 chat, text-embedding-01 embed)
# ----------------------------------------------------------------------------
INTELLIQX_LLM_BACKEND=fake

# MiniMax credentials (only used when INTELLIQX_LLM_BACKEND=minimax).
# Get an API key from https://api.minimax.io and paste it below.
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1

# ----------------------------------------------------------------------------
# Storage, state, and vector index — only the local profile is enabled
# here. For production, switch INTELLIQX_CLOUD to the right profile and
# set the corresponding cloud credentials further down.
# ----------------------------------------------------------------------------
INTELLIQX_OBJECT_STORE=memory
INTELLIQX_VECTOR_BACKEND=memory
INTELLIQX_VECTOR_DIM=768
INTELLIQX_VECTOR_DB=:memory:

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
INTELLIQX_OTEL=0
INTELLIQX_LOGS_JSON=0

# ----------------------------------------------------------------------------
# Cloud credentials (only used when INTELLIQX_CLOUD=aws|gcp|modal).
# Leave commented out for the local profile.
# ----------------------------------------------------------------------------
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_APPLICATION_CREDENTIALS=
#
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
#
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
